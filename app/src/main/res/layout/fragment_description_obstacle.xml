<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:background="#142033">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_arrow_back_24"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Description de l'obstacle"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="74dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="@drawable/bg_screen3_card">

                <TextView
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:gravity="center"
                    android:text="📷"
                    android:textSize="24sp"
                    android:background="@drawable/bg_screen3_photo_icon" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Photo ajoutée"
                        android:textColor="#1F2A44"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cliquez pour voir l'aperçu"
                        android:textColor="#8B95A7"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_screen3_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Catégorie d'obstacle *"
                    android:textColor="#1F2A44"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/categoryDechet"
                        style="@style/Screen3Chip"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:text="Déchet" />

                    <TextView
                        android:id="@+id/categoryObstacle"
                        style="@style/Screen3Chip"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Obstacle" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="7dp">

                    <TextView
                        android:id="@+id/categoryBranche"
                        style="@style/Screen3Chip"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:text="Branche" />

                    <TextView
                        android:id="@+id/categoryCarton"
                        style="@style/Screen3Chip"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Carton/Sac" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="7dp">

                    <TextView
                        android:id="@+id/categoryVerre"
                        style="@style/Screen3Chip"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:text="Verre/Débris" />

                    <TextView
                        android:id="@+id/categoryMobilier"
                        style="@style/Screen3Chip"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Mobilier" />
                </LinearLayout>

                <TextView
                    android:id="@+id/categoryAutre"
                    style="@style/Screen3Chip"
                    android:layout_width="match_parent"
                    android:layout_marginTop="7dp"
                    android:text="Autre" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_screen3_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Taille estimée *"
                    android:textColor="#1F2A44"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/sizePetit"
                        style="@style/Screen3Chip"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:text="Petit" />

                    <TextView
                        android:id="@+id/sizeMoyen"
                        style="@style/Screen3Chip"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Moyen" />

                    <TextView
                        android:id="@+id/sizeGrand"
                        style="@style/Screen3Chip"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Grand" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_screen3_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Niveau de danger *"
                    android:textColor="#1F2A44"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/dangerFaible"
                        style="@style/Screen3Chip"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:text="Faible" />

                    <TextView
                        android:id="@+id/dangerModere"
                        style="@style/Screen3Chip"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Modéré" />

                    <TextView
                        android:id="@+id/dangerEleve"
                        style="@style/Screen3Chip"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Élevé" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_screen3_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Commentaire (optionnel)"
                    android:textColor="#1F2A44"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/editComment"
                    android:layout_width="match_parent"
                    android:layout_height="94dp"
                    android:gravity="top"
                    android:padding="12dp"
                    android:textColor="#1F2A44"
                    android:textSize="13sp"
                    android:hint="Ajoutez des détails sur l'obstacle, sa position exacte..."
                    android:textColorHint="#A2AABD"
                    android:background="@drawable/bg_screen3_edit_text"
                    android:inputType="textMultiLine|textCapSentences" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnValidateDescription"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="Valider la description →"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:background="@drawable/bg_screen3_primary_button" />

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Retour"
                android:textColor="#1F2A44"
                android:textStyle="bold"
                android:textSize="13sp"
                android:background="@drawable/bg_screen3_secondary_button" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>