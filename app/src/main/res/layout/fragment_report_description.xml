<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1E2A3A"
        android:paddingHorizontal="16dp">

        <TextView
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="24sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Description de l'obstacle"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="#F5F7FA"
                    android:padding="8dp"
                    android:src="@mipmap/icone_photo" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Photo ajoutée"
                        android:textColor="#111827"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cliquez pour voir l'aperçu"
                        android:textColor="#64748B"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Type de signalement *"
                android:textColor="#111827"
                android:textStyle="bold" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <EditText
                    android:id="@+id/issueTypeEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:hint="Ex : Obstacle sur la chaussée"
                    android:padding="12dp"
                    android:paddingEnd="48dp"
                    android:textColor="#111827"
                    android:textColorHint="#64748B"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/mic_icon_type"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="12dp"
                    android:src="@mipmap/microphone" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Catégorie d'obstacle *"
                android:textColor="#111827"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:columnCount="2">

                <Button
                    android:id="@+id/btn_cat_dechet"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:backgroundTint="#FFFFFF"
                    android:text="Déchet"
                    android:textAllCaps="false"
                    android:textColor="#111827" />

                <Button
                    android:id="@+id/btn_cat_obstacle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:backgroundTint="#FFFFFF"
                    android:text="Obstacle"
                    android:textAllCaps="false"
                    android:textColor="#111827" />

                <Button
                    android:id="@+id/btn_cat_branche"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:backgroundTint="#FFFFFF"
                    android:text="Branche"
                    android:textAllCaps="false"
                    android:textColor="#111827" />

                <Button
                    android:id="@+id/btn_cat_carton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:backgroundTint="#FFFFFF"
                    android:text="Carton/Sac"
                    android:textAllCaps="false"
                    android:textColor="#111827" />

                <Button
                    android:id="@+id/btn_cat_verre"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:backgroundTint="#FFFFFF"
                    android:text="Verre/Débris"
                    android:textAllCaps="false"
                    android:textColor="#111827" />

                <Button
                    android:id="@+id/btn_cat_mobilier"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:backgroundTint="#FFFFFF"
                    android:text="Mobilier"
                    android:textAllCaps="false"
                    android:textColor="#111827" />

                <Button
                    android:id="@+id/btn_cat_autre"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:backgroundTint="#FFFFFF"
                    android:text="Autre"
                    android:textAllCaps="false"
                    android:textColor="#111827" />
            </GridLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Contexte du signalement *"
                android:textColor="#111827"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/urbanContextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_weight="1"
                    android:backgroundTint="#2563FF"
                    android:text="Urbain"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/highwayContextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_weight="1"
                    android:backgroundTint="#FFFFFF"
                    android:text="Autoroute"
                    android:textAllCaps="false"
                    android:textColor="#111827" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Taille estimée *"
                android:textColor="#111827"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_size_petit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_weight="1"
                    android:backgroundTint="#FFFFFF"
                    android:text="Petit"
                    android:textAllCaps="false"
                    android:textColor="#111827" />

                <Button
                    android:id="@+id/btn_size_moyen"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_weight="1"
                    android:backgroundTint="#FFFFFF"
                    android:text="Moyen"
                    android:textAllCaps="false"
                    android:textColor="#111827" />

                <Button
                    android:id="@+id/btn_size_grand"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_weight="1"
                    android:backgroundTint="#FFFFFF"
                    android:text="Grand"
                    android:textAllCaps="false"
                    android:textColor="#111827" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Niveau de danger *"
                android:textColor="#111827"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_danger_faible"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_weight="1"
                    android:backgroundTint="#FFFFFF"
                    android:text="Faible"
                    android:textAllCaps="false"
                    android:textColor="#111827" />

                <Button
                    android:id="@+id/btn_danger_modere"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_weight="1"
                    android:backgroundTint="#FFFFFF"
                    android:text="Modéré"
                    android:textAllCaps="false"
                    android:textColor="#111827" />

                <Button
                    android:id="@+id/btn_danger_eleve"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_weight="1"
                    android:backgroundTint="#FFFFFF"
                    android:text="Élevé"
                    android:textAllCaps="false"
                    android:textColor="#111827" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Commentaire (optionnel)"
                android:textColor="#111827"
                android:textStyle="bold" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <EditText
                    android:id="@+id/issueCommentEditText"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="#FFFFFF"
                    android:gravity="top"
                    android:hint="Ajoutez des détails sur l'obstacle, sa position exacte,"
                    android:padding="12dp"
                    android:paddingEnd="48dp"
                    android:textColor="#111827"
                    android:textColorHint="#64748B"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/mic_icon_comment"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="end|top"
                    android:layout_marginEnd="12dp"
                    android:layout_marginTop="12dp"
                    android:src="@mipmap/microphone" />
            </FrameLayout>

            <TextView
                android:id="@+id/text_address_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="#64748B"
                android:textSize="12sp" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <Button
            android:id="@+id/btn_validate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#2563FF"
            android:text="Valider la description →"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#FFFFFF"
            android:text="Retour"
            android:textAllCaps="false"
            android:textColor="#111827" />
    </LinearLayout>

</LinearLayout>